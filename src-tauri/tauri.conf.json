{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Interlude",
  "version": "1.0.0",
  "identifier": "com.interlude.app",
  "build": {
    "beforeBuildCommand": "npm run build:web",
    "beforeDevCommand": "npm run dev:web",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "bundle": {
    "active": true,
    "category": "Music",
    "copyright": "© 2024 Interlude",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "longDescription": "A high-resolution audio player with Spotify-style UX",
    "shortDescription": "Hi-Res Audio Player",
    "targets": "all",
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "macOS": {
      "entitlements": null,
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 800,
        "minHeight": 600,
        "minWidth": 1000,
        "resizable": true,
        "title": "Interlude",
        "width": 1400,
        "decorations": false,
        "transparent": false,
        "center": true
      }
    ]
  }
}
